<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="140dp">
        <TextView
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold"
            android:id="@+id/text_contact_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/switch_active"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.google.android.material.chip.Chip
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@android:color/white"
            android:id="@+id/chip_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxWidth="200dp"
            app:chipBackgroundColor="@color/design_default_color_primary"
            app:chipMinHeight="28dp"
            app:ensureMinTouchTargetSize="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_contact_name"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?android:attr/textColorSecondary"
            android:ellipsize="end"
            android:id="@+id/text_message_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:maxLines="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/chip_status"/>
        <LinearLayout
            android:gravity="start"
            android:orientation="horizontal"
            android:id="@+id/msg_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_message_preview">
            <TextView
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/text_schedule_time"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Tomorrow, 9:00 AM"
                android:drawablePadding="6dp"
                app:drawableStartCompat="@drawable/ic_schedule"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_message_preview"/>
            <ImageView
                android:id="@+id/icon_has_image"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_attach_image"
                android:contentDescription="@string/schedule_image_attached"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/text_schedule_time"
                app:layout_constraintStart_toEndOf="@+id/text_schedule_time"
                app:layout_constraintTop_toTopOf="@+id/text_schedule_time"
                app:tint="?attr/colorPrimary"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="end"
            android:orientation="horizontal"
            android:id="@+id/actions_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageButton
                android:id="@+id/button_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/edit2"
                android:scaleType="centerInside"
                android:contentDescription="@string/swipe_conversation_action_edit"
                app:tint="?attr/colorPrimary"/>
            <ImageButton
                android:id="@+id/button_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/trash"
                android:scaleType="centerInside"
                android:contentDescription="@string/swipe_conversation_action_delete"
                android:layout_marginStart="4dp"
                app:tint="?attr/colorError"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?android:attr/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintBottom_toTopOf="@+id/button_save"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="96dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_contact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/schedule_select_contact"
                app:startIconDrawable="@drawable/ic_person"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_contact"
                    android:focusable="false"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_whatsapp_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/schedule_whatsapp_type"/>
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_whatsapp_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:selectionRequired="true"
                        app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggle_whatsapp_normal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_whatsapp_normal"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            style="?attr/materialButtonOutlinedStyle"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggle_whatsapp_business"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_whatsapp_business"
                            android:layout_weight="1"
                            style="?attr/materialButtonOutlinedStyle"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/message"
                app:counterEnabled="true"
                app:counterMaxLength="65535"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:gravity="top"
                    android:id="@+id/edit_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="6"
                    android:minLines="3"
                    android:inputType="textMultiLine"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_image_attachment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_attach_image"
                            android:contentDescription="@string/schedule_attach_image"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:id="@+id/text_image_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_attach_image"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_attach_image"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/select"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_remove_image"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_remove_image"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    </LinearLayout>
                    <FrameLayout
                        android:id="@+id/image_preview_container"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <ImageView
                            android:id="@+id/image_preview"
                            android:background="?attr/colorSurfaceVariant"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/schedule_attach_image"/>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:hint="@string/schedule_date"
                            android:layout_weight="1"
                            app:startIconDrawable="@drawable/ic_schedule"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_date"
                                android:focusable="false"
                                android:clickable="true"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_time"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:hint="@string/schedule_time"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            app:startIconDrawable="@drawable/ic_schedule"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_time"
                                android:focusable="false"
                                android:clickable="true"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_repeat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/schedule_repeat"/>
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/group_repeat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:chipSpacing="8dp"
                        app:selectionRequired="true"
                        app:singleLine="false"
                        app:singleSelection="true">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_repeat_once"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_repeat_once"
                            app:chipMinHeight="48dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_repeat_daily"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_repeat_daily"
                            app:chipMinHeight="48dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_repeat_weekly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_repeat_weekly"
                            app:chipMinHeight="48dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_repeat_monthly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_repeat_monthly"
                            app:chipMinHeight="48dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_repeat_custom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_repeat_custom"
                            app:chipMinHeight="48dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>
                    </com.google.android.material.chip.ChipGroup>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/days_of_week_container"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/schedule_select_days"/>
                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:chipSpacing="8dp"
                            app:singleLine="false">
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_sunday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_sun"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_monday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_mon"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_tuesday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_tue"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_wednesday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_wed"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_thursday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_thu"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_friday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_fri"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_saturday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_sat"
                                app:chipMinHeight="48dp"
                                style="@style/Widget.MaterialComponents.Chip.Filter"/>
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/save"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/ModernButton"/>
</androidx.constraintlayout.widget.ConstraintLayout>
